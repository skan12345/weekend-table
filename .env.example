# Copy to .env (local) and add the same vars in Vercel → Project → Settings → Environment Variables.
# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional. Only needed if you want the resolver to also fill in street addresses.
# (Server-side only — never prefix this with VITE_.)
# GOOGLE_MAPS_API_KEY=YOUR-KEY
